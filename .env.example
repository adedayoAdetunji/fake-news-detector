# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Database Configuration
# Leave unset for local SQLite, or set MySQL in production.
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/fake_news_detector

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@fakenewsdetector.local

# Email Configuration (optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com
REPORT_RECIPIENT=admin@example.com

# Google Fact Check Tools API
# Create an API key in Google Cloud and enable Fact Check Tools API.
GOOGLE_FACT_CHECK_API_KEY=your-real-key

# Google Custom Search JSON API
# Requires an API key plus a Programmable Search Engine ID.
GOOGLE_SEARCH_API_KEY=your-real-key
GOOGLE_SEARCH_ENGINE_ID=your-real-search-engine-id

# Multilingual Support
ENABLE_NIGERIAN_LANGUAGES=True
SUPPORTED_LANGUAGES=en,yo,ha,ig
